# ==========================================================================
# Variáveis de ambiente da instalação STANDALONE da discovery-ui (sem
# subir NetBox junto -- aponta pra um NetBox que já existe no cliente).
# Copie para ".env.discovery-ui" e preencha antes de instalar.
# NUNCA versione o arquivo ".env.discovery-ui" real (com segredos) em
# git público.
# ==========================================================================

# ---- NetBox já existente do cliente (fora deste compose) ----
# Token precisa ter permissão de escrita em dcim (devices, interfaces)
# e ipam (ip addresses) -- é o que o "Aprovar e gravar no NetBox" usa.
NETBOX_URL=http://IP_OU_HOST_DO_NETBOX:8000
NETBOX_TOKEN=token-de-api-do-netbox-do-cliente

# ---- Login da interface web (não integrado ao NetBox) ----
DISCOVERY_UI_USER=admin
DISCOVERY_UI_PASSWORD=troque-esta-senha
DISCOVERY_UI_SECRET_KEY=troque-esta-chave-aleatoria
