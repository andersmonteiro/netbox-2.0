# ==========================================================================
# orb-agent/agent.yaml.example
#
# Config do Orb Agent (descoberta de rede da NetBox Labs). Ele varre a
# rede/conecta nos devices e manda o resultado pro Diode, que reconcilia
# e aplica no NetBox. Requer a stack do Diode já rodando (README, seção
# "Diode") e o plugin netbox_diode_plugin habilitado (já está em
# plugin_requirements.txt / configuration/plugins.py).
#
# Copie para agent.yaml, preencha os alvos e rode (seção 2.3 do README).
# Referência oficial: https://netboxlabs.com/docs/orb-agent/config_samples
#
# IMPORTANTE -- dois comportamentos DIFERENTES de "${VAR}" no mesmo
# arquivo, confirmados em produção:
#   - backends.common.diode.client_id / client_secret: NÃO expande
#     "${VAR}" (testamos -- ele manda a string literal "${DIODE_CLIENT_ID}"
#     pro Diode e a autenticação falha). Preencha com o VALOR REAL direto
#     no arquivo.
#   - policies.device_discovery.*.scope[].password e
#     policies.snmp_discovery.*.scope.authentication.{community,username,
#     auth_passphrase,priv_passphrase}: a documentação oficial afirma que
#     ESSES campos suportam "${VAR}" de verdade (resolvido via variável
#     de ambiente passada no "docker run -e"). Não teste ainda em produção
#     neste template -- se não expandir (mesmo bug do bloco diode), o
#     sintoma é igual: credencial errada chega no destino. Confira o log
#     (docker logs orb-agent) depois do primeiro deploy pra confirmar.
# Por causa do client_secret e/ou senha real que pode acabar aqui dentro,
# agent.yaml (diferente deste .example) está no .gitignore -- nunca
# commite ele.
# ==========================================================================

orb:
  config_manager:
    active: local

  backends:
    # Varredura de rede (ping/porta) — descobre hosts ativos numa faixa,
    # sem credencial nenhuma. Só sabe "tem algo vivo aqui, essas portas
    # estão abertas" -- não sabe modelo/fabricante/interfaces. Bom ponto
    # de partida pra saber o que existe na rede.
    network_discovery:
    # Conecta via SSH/NAPALM em devices JÁ CONHECIDOS (você informa IP +
    # credencial de cada um) e coleta inventário de verdade: interfaces,
    # versão de SO, seriais. Não serve pra "descobrir o desconhecido" --
    # é o passo de enriquecimento depois que você já sabe o que existe.
    device_discovery:
    # Idem, mas via SNMP em vez de SSH -- não precisa de usuário/senha de
    # shell, só da community (SNMPv2c) ou credenciais SNMPv3. Costuma ser
    # mais fácil de habilitar em switch/roteador que já tem SNMP ligado
    # pra monitoramento (Zabbix etc.) do que abrir acesso SSH novo.
    snmp_discovery:
    # Comente os blocos (e as policies correspondentes abaixo) que você
    # não for usar.

    common:
      diode:
        # Endereço gRPC do Diode server (mesma stack da seção "Diode").
        target: grpc://SEU_DIODE_HOST:8080/diode
        # client_id/client_secret do client "diode-ingest" (criado
        # automaticamente pelo quickstart.sh do Diode -- pegue com:
        #   jq -r '.[] | select(.client_id=="diode-ingest") | .client_secret' \
        #     /opt/diode/oauth2/client/client-credentials.json
        # Valor LITERAL aqui, não "${VAR}" (não funciona, ver nota acima).
        client_id: diode-ingest
        client_secret: SUBSTITUA_PELO_SECRET_REAL
        agent_name: orb-agent-01

  policies:
    network_discovery:
      varredura_geral:
        config:
          # Roda a cada 2 horas. Ajuste o cron conforme a rede do cliente.
          schedule: "0 */2 * * *"
          # ATENÇÃO: timeout é em MINUTOS (não segundos -- confirmado em
          # produção: "timeout: 5" apareceu como "5m0s" no log e o scan
          # foi morto por estourar o prazo). Em blocos públicos, muitos
          # hosts não respondem e o nmap demora até desistir de cada um
          # -- comece com uma folga generosa (15-20) e ajuste depois. Se
          # continuar estourando, considere reduzir o escopo, usar
          # "ports: [22, 80, 443, ...]" pra restringir a varredura, ou
          # "scan_types: [connect]" + "skip_host: true" (mais rápido,
          # ver https://netboxlabs.com/docs/orb-agent/config_samples).
          timeout: 20
          defaults:
            description: "Descoberto via orb-agent (network_discovery)"
            tags: ["auto-discovered", "orb-agent"]
        scope:
          # Troque pelas subnets reais do cliente.
          targets: [192.168.0.0/24, 10.0.0.0/16]

    # Enriquecimento via SSH/NAPALM -- um item por device JÁ CONHECIDO
    # (mesmo padrão do automation-scripts/napalm_collect.py, mas via
    # Diode). "driver" segue o NAPALM (ios, eos, nxos, junos, etc.).
    device_discovery:
      devices_conhecidos:
        config:
          schedule: "0 */6 * * *"
          defaults:
            site: "Matriz"
        scope:
          - driver: ios
            hostname: 192.168.0.5
            username: admin
            # Documentação oficial diz que "${VAR}" funciona aqui (via
            # -e DEVICE_PASSWORD=... no docker run) -- ver nota no topo
            # do arquivo sobre confirmar isso no seu ambiente.
            password: ${DEVICE_PASSWORD}
            # Se precisar de bastion/jumphost pra chegar no device, veja
            # "Device Discovery with Jumphost" na doc oficial (optional_args
            # .ssh_config_file apontando pra um arquivo de config do SSH).

    # Enriquecimento via SNMP -- não precisa de SSH, só da community
    # (SNMPv2c) ou credenciais SNMPv3 já configuradas nos equipamentos.
    snmp_discovery:
      snmp_rede_conhecida:
        config:
          schedule: "0 */6 * * *" # a cada 6 horas
          timeout: 300            # timeout da policy inteira, em segundos
          snmp_timeout: 10        # timeout por operação SNMP, em segundos
          retries: 3
          defaults:
            tags: ["snmp-discovery", "orb-agent"]
            site: "Matriz"
            device:
              description: "Descoberto via orb-agent (snmp_discovery)"
        scope:
          targets:
            - host: "192.168.0.1"
            - host: "192.168.0.254"
            # - host: "10.0.0.1"
            #   port: 162  # porta SNMP não padrão, se precisar
          authentication:
            protocol_version: "SNMPv2c"
            # Documentação oficial diz que "${VAR}" funciona aqui (via
            # -e SNMP_COMMUNITY=... no docker run) -- ver nota no topo
            # do arquivo sobre confirmar isso no seu ambiente. Se não
            # expandir, troque pelo valor literal da community.
            community: ${SNMP_COMMUNITY}
            # Pra SNMPv3, troque o bloco acima por (exemplo):
            # protocol_version: "SNMPv3"
            # security_level: "authPriv"
            # username: ${SNMP_USERNAME}
            # auth_protocol: "SHA"
            # auth_passphrase: ${SNMP_AUTH_PASSPHRASE}
            # priv_protocol: "AES"
            # priv_passphrase: ${SNMP_PRIV_PASSPHRASE}
