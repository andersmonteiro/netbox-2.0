# ==========================================================================
# Variáveis de ambiente do projeto NetBox
# Copie este arquivo para ".env" e ajuste os valores antes de subir a stack.
# NUNCA versione o arquivo ".env" real (com segredos) em git público.
# ==========================================================================

# ---- NetBox (usadas pelo docker-compose.override.yml do repositório oficial) ----
# Veja também netbox-docker/env/netbox.env para a lista completa de variáveis.
#
# IMPORTANTE: o netbox-docker vem com SKIP_SUPERUSER=true por padrão
# (definido em env/netbox.env, dentro do repositório oficial). Sem essa
# linha aqui sobrescrevendo pra "false", o container NUNCA cria o
# usuário admin, mesmo com SUPERUSER_PASSWORD preenchido -- login falha
# silenciosamente porque o usuário simplesmente não existe no banco.
SKIP_SUPERUSER=false

SUPERUSER_NAME=admin
SUPERUSER_EMAIL=admin@example.com
SUPERUSER_PASSWORD=troque-esta-senha
# A partir do NetBox 4.3 (token de API "v2"), é preciso das DUAS
# variáveis abaixo pro token ser criado -- só SUPERUSER_API_TOKEN não
# basta. Gere valores aleatórios, ex: openssl rand -hex 20 / -hex 16
SUPERUSER_API_TOKEN=troque-este-token-de-40-caracteres
SUPERUSER_API_KEY=troque-esta-chave-de-32-caracteres

NETBOX_URL=http://localhost:8000

# ---- netbox-zabbix-sync ----
ZABBIX_HOST=https://zabbix.suaempresa.local
ZABBIX_TOKEN=token-api-do-zabbix
NETBOX_HOST=http://netbox:8080
NETBOX_TOKEN=${SUPERUSER_API_TOKEN}

# ---- NetBox MCP Server (agente de IA) ----
MCP_NETBOX_URL=http://netbox:8080
MCP_NETBOX_TOKEN=${SUPERUSER_API_TOKEN}
MCP_TRANSPORT=http
MCP_PORT=8001

# ---- Diode (ingestão automática de dados de descoberta) ----
DIODE_TOKEN=troque-este-token-diode
DIODE_NETBOX_TOKEN=${SUPERUSER_API_TOKEN}
