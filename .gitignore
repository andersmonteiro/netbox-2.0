# ==========================================================================
# Este repositório é um TEMPLATE reaproveitável entre clientes.
# Nada com dado real de cliente (senha, token, IP, planilha) deve ser
# commitado aqui. Cada deploy usa seu próprio .env fora do git.
# ==========================================================================

# Segredos / config por ambiente
.env
.env.discovery-ui
**/client-data/
**/*.secrets.py

# Repositório oficial do NetBox, clonado pelo setup.sh a cada deploy —
# não vendorizamos ele aqui, sempre puxamos a versão mais recente.
/netbox-docker/

# Config real do Orb Agent (contém client_secret do Diode em texto
# plano). Só o .example fica versionado.
orb-agent/agent.yaml

# Dumps de banco crus (não processados) -- só netbox-seed/device-catalog.sql
# (limpo de senha/sessão/audit log, ver README seção 2.5) é versionado.
ndoc_db_clean_install.sql
*.sql
!netbox-seed/device-catalog.sql

# Saída do discovery_netbox.py -- JSON com IP/interface/hostname reais
# de cliente, staging antes de aplicar no NetBox.
automation-scripts/discovery_output/

# Planilhas de importação (dados reais de cliente)
automation-scripts/planilhas/
*.xlsx
*.xls
!**/exemplos/*.xlsx

# Python
__pycache__/
*.pyc
.venv/
*.egg-info/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
